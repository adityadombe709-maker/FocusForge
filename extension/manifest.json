{
  "manifest_version": 3,
  "name": "FocusForge Guard",
  "version": "1.0.0",
  "description": "A timer extension with website whitelist/blacklist to help you stay focused.",

  "permissions": ["activeTab", "scripting", "storage", "tabs"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "FocusForge Timer"
  },

  "host_permissions": ["<all_urls>"],

  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*", "http://127.0.0.1:5173/*"],
      "js": ["content.js"]
    }
  ]
}
